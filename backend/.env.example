# Database: backend and connection (ORM used when DATABASE_BACKEND=sql)
DATABASE_BACKEND=mongodb
# MongoDB (when DATABASE_BACKEND=mongodb)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=omegaweb
# SQL (when DATABASE_BACKEND=sql). SQLite default; or postgresql+asyncpg://user:pass@localhost/db
# DATABASE_URL=sqlite+aiosqlite:///./omegaweb.db

# Translation Memory
TM_FUZZY_THRESHOLD=75

# AI translation: engine-agnostic. Set AI_PROVIDER to one of: openai, anthropic
AI_PROVIDER=openai

# OpenAI (when AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (when AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Optional: path to seed JSON files (default: backend/data/seeds). Use for any DB.
# SEEDS_DIR=/path/to/seeds
